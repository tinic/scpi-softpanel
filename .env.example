# Configuration for the headless server (rust/scpi-server). The desktop app reads
# the same vars but prefers a persisted target from its OS config dir.

# --- Instrument (raw SCPI socket) ---
# The meter is addressed as a raw TCP socket: TCPIP::<host>::<port>::SOCKET.
METER_HOST=192.168.1.166
METER_PORT=5025
# Connect timeout / per-command I/O timeout, milliseconds.
METER_TIMEOUT_MS=5000

# --- Polling ---
# Live-reading poll interval (ms). Interacts with NPLC: high NPLC => fewer readings/sec.
POLL_INTERVAL_MS=100
# Start polling automatically once connected.
POLL_AUTOSTART=true

# --- Reading store (in-memory ring) ---
RING_CAPACITY=3600

# --- Server ---
PORT=8080
HOST=0.0.0.0
# Directory containing the built web UI (apps/web/dist). API/WS-only if unset/missing.
WEB_DIST=../apps/web/dist
# Optional: persist the meter target (host/port) saved from the settings UI to this file.
CONFIG_PATH=
