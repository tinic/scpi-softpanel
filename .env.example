# --- Instrument ---
# Full VISA resource string (takes precedence over METER_HOST when set).
#   VXI-11 (recommended): TCPIP::192.168.1.166::INSTR
#   Raw socket:           TCPIP::192.168.1.166::5025::SOCKET
METER_RESOURCE=TCPIP::192.168.1.166::INSTR
# Convenience: if METER_RESOURCE is empty, a VXI-11 resource is built from this host.
METER_HOST=192.168.1.166
# VISA I/O timeout in milliseconds.
METER_TIMEOUT_MS=5000
# Reconnect is gated by a cheap TCP reachability probe so the broker never fires
# VXI-11/RPC traffic at a meter that is off or still booting (which can wedge its
# startup). Port probed for "is the meter up?" — the raw SCPI socket by default.
METER_PROBE_PORT=5025
# After the meter first becomes reachable, wait this long before opening the
# single control session, to let it finish booting.
METER_BOOT_SETTLE_MS=8000

# --- Polling ---
# Live-reading poll interval (ms). Interacts with NPLC: high NPLC => fewer readings/sec.
POLL_INTERVAL_MS=100
# Start polling automatically on launch.
POLL_AUTOSTART=true

# --- Reading store (in-memory ring) ---
RING_CAPACITY=3600

# --- Server ---
PORT=8080
HOST=0.0.0.0

# --- Bridge ---
# Python interpreter used to run the pyvisa bridge (defaults to the bundled venv).
BRIDGE_PYTHON=bridge/.venv/bin/python
